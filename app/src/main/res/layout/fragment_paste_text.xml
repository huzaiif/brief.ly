<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">


    <View
        android:id="@+id/inputHeader"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/grad_secondary"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvInputTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:text="Paste Text"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:fontFamily="@font/san_francisco"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ready to extract some insights?"
        android:textColor="@color/glass_white"
        android:textSize="16sp"
        android:fontFamily="@font/san_francisco"
        app:layout_constraintStart_toStartOf="@id/tvInputTitle"
        app:layout_constraintTop_toBottomOf="@id/tvInputTitle" />

    <!-- Input Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-40dp"
        android:layout_marginBottom="24dp"
        style="@style/PremiumCard"
        app:layout_constraintBottom_toTopOf="@id/btnSummarize"
        app:layout_constraintTop_toBottomOf="@id/inputHeader">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPasteText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            app:boxBackgroundMode="none"
            app:hintEnabled="false"
            app:counterEnabled="true"
            app:counterTextColor="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPasteText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="top"
                android:hint="Start typing or paste your content here..."
                android:inputType="textMultiLine"
                android:background="@null"
                android:padding="8dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp"
                android:fontFamily="@font/san_francisco" />
        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSummarize"
        style="@style/PremiumButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="24dp"
        android:text="Summarize with AI"
        android:fontFamily="@font/san_francisco"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:elevation="10dp"
        android:indeterminateTint="@color/grad_primary_start"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>