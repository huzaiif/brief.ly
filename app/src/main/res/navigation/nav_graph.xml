<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.briefly.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_signupFragment"
            app:destination="@id/signupFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/signupFragment"
        android:name="com.example.briefly.ui.auth.SignupFragment"
        android:label="Signup"
        tools:layout="@layout/fragment_signup">
        <action
            android:id="@+id/action_signupFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.briefly.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_pasteTextFragment"
            app:destination="@id/pasteTextFragment" />
        <action
            android:id="@+id/action_homeFragment_to_savedSummariesFragment"
            app:destination="@id/savedSummariesFragment" />
        <action
            android:id="@+id/action_homeFragment_to_webViewFragment"
            app:destination="@id/webViewFragment" />
        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/pasteTextFragment"
        android:name="com.example.briefly.ui.summary.PasteTextFragment"
        android:label="Paste Text"
        tools:layout="@layout/fragment_paste_text">
        <argument
            android:name="extractedText"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_pasteTextFragment_to_resultFragment"
            app:destination="@id/resultFragment" />
    </fragment>

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.example.briefly.ui.summary.ResultFragment"
        android:label="Summary Result"
        tools:layout="@layout/fragment_result">
        <argument
            android:name="originalText"
            app:argType="string" />
        <argument
            android:name="summary"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/savedSummariesFragment"
        android:name="com.example.briefly.ui.saved.SavedSummariesFragment"
        android:label="Saved Summaries"
        tools:layout="@layout/fragment_saved_summaries">
        <action
            android:id="@+id/action_savedSummariesFragment_to_resultFragment"
            app:destination="@id/resultFragment" />
    </fragment>

    <fragment
        android:id="@+id/webViewFragment"
        android:name="com.example.briefly.ui.research.WebViewFragment"
        android:label="Research"
        tools:layout="@layout/fragment_web_view" />

</navigation>