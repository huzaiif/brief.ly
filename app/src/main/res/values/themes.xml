<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Briefly" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/grad_primary_start</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/grad_secondary_start</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/grad_primary_start</item>
        
        <!-- Main Text Font -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.Briefly" parent="Base.Theme.Briefly">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_light</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Briefly</item>
    </style>

    <!-- Premium Card Style -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@color/bg_surface</item>
    </style>

    <!-- Premium Button Style -->
    <style name="PremiumButton" parent="Widget.Material3.Button">
        <item name="android:background">@drawable/bg_button_gradient</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Premium Input Style -->
    <style name="PremiumInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/grad_primary_start</item>
        <item name="hintTextColor">@color/grad_primary_start</item>
    </style>
</resources>