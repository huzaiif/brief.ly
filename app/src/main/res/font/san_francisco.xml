<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Regular -->
    <font
        android:font="@font/sfprodisplayregular"
        android:fontStyle="normal"
        android:fontWeight="400"
        app:font="@font/sfprodisplayregular"
        app:fontStyle="normal"
        app:fontWeight="400" />

    <!-- Medium -->
    <font
        android:font="@font/sfprodisplaymedium"
        android:fontStyle="normal"
        android:fontWeight="500"
        app:font="@font/sfprodisplaymedium"
        app:fontStyle="normal"
        app:fontWeight="500" />

    <!-- Bold -->
    <font
        android:font="@font/sfprodiplaybold"
        android:fontStyle="normal"
        android:fontWeight="700"
        app:font="@font/sfprodiplaybold"
        app:fontStyle="normal"
        app:fontWeight="700" />

</font-family>